# SigmaLab (PH1) example environment file

# Runtime environment: local|dev|test|prod
SIGMALAB_ENV=local

# Logging
SIGMALAB_LOG_LEVEL=INFO

# Database (PostgreSQL is the intended persisted application database)
SIGMALAB_DATABASE_URL=postgresql+psycopg://sigmalab:sigmalab@localhost:5432/sigmalab
SIGMALAB_DATABASE_ECHO=false

# Zerodha Kite placeholders (never commit real credentials)
SIGMALAB_KITE_API_KEY=
SIGMALAB_KITE_API_SECRET=

